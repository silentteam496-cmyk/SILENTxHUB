-- FUNGSI VALIDASI UTAMA
local function EksekusiCekJawaban()
	if Terverifikasi then return end

	local KunciJawaban = string.lower(ListPertanyaan[IndeksSkrg].Jawab)
	local InputUserClean = string.lower(string.gsub(JawabanUser, "%s+", ""))

	if InputUserClean == KunciJawaban then
		Terverifikasi = true
		WindUI:Notify({
			Title = "VERIFIED SUCCESS ✅",
			Content = "Jawaban Benar! Semua fitur tab kini aktif.",
			Duration = 5
		})
		LabelPertanyaan:SetTitle("STATUS: VERIFIED")
		LabelPertanyaan:SetDesc("Akses penuh berhasil dibuka. Silahkan pilih tab fitur di sidebar kiri!")
	else
		WindUI:Notify({
			Title = "WRONG ANSWER ❌",
			Content = "Jawaban salah, coba lagi atau ganti pertanyaan!",
			Duration = 4
		})
	end
end

