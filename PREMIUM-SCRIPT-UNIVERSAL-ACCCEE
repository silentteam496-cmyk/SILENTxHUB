local AvatarTab = Window:Tab({Title="AVATAR", Icon="user"})

AvatarTab:Section({Title="👤 AVATAR STALKER"})

local TargetAvatarPlayer = ""

-- Dropdown untuk mencari player
local PlayerDropdown = AvatarTab:Dropdown({
	Title = "SEARCH PLAYER",
	Desc = "Pilih pemain di server untuk disalin avatarnya",
	Options = {}, 
	Callback = function(SelectedName)
		TargetAvatarPlayer = SelectedName
	end
})

-- Fungsi memperbarui daftar player di dropdown secara real-time
local function UpdateDropdownPlayers()
	local currentPlayers = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then 
            table.insert(currentPlayers, p.Name) 
        end
	end
	if PlayerDropdown and PlayerDropdown.SetOptions then
		PlayerDropdown:SetOptions(currentPlayers)
	elseif PlayerDropdown and PlayerDropdown.Refresh then
		PlayerDropdown:Refresh(currentPlayers, true)
	end
end

-- Looping otomatis update daftar player setiap 3 detik
task.spawn(function()
	while task.wait(3) do
		UpdateDropdownPlayers()
	end
end)

-- Tombol Clone Avatar
AvatarTab:Button({
	Title = "➡️ ENTER AVATAR",
	Desc = "Salin penampilan player pilihan",
	Callback = function()
		if TargetAvatarPlayer == "" then
			WindUI:Notify({Title = "ERROR", Content = "Silahkan pilih target player di Dropdown dulu!", Duration = 3})
			return
		end
		
		local TargetPlr = Players:FindFirstChild(TargetAvatarPlayer)
		if TargetPlr and TargetPlr.Character and LocalPlayer.Character then
			local LocalHum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
			if LocalHum then
				local Success, Desc = pcall(function() 
                    return Players:GetHumanoidDescriptionFromUserId(TargetPlr.UserId) 
                end)
				if Success and Desc then
					LocalHum:ApplyDescription(Desc)
					WindUI:Notify({Title = "AVATAR CLONED ✅", Content = "Berhasil menyalin avatar dari: " .. TargetAvatarPlayer, Duration = 4})
				else
					WindUI:Notify({Title = "ERROR", Content = "Gagal memuat asset catalog player.", Duration = 3})
				end
			end
		else
			WindUI:Notify({Title = "ERROR", Content = "Player tidak ditemukan atau karakter belum memuat.", Duration = 3})
		end
	end
})

-- Tombol Reset Avatar
AvatarTab:Button({
	Title = "🔄 RESET AVATAR",
	Desc = "Kembalikan penampilan asli Anda",
	Callback = function()
		if LocalPlayer.Character then
			local LocalHum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
			if LocalHum then
				local Success, Desc = pcall(function() 
                    return Players:GetHumanoidDescriptionFromUserId(LocalPlayer.UserId) 
                end)
				if Success and Desc then
					LocalHum:ApplyDescription(Desc)
					WindUI:Notify({Title = "AVATAR RESETED 🔄", Content = "Avatar Anda telah kembali ke semula.", Duration = 3})
				else
					LocalPlayer:LoadCharacter()
				end
			end
		end
	end
})
